<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <%
    const seoTitle = (page && page.seo && page.seo.title)
        ? page.seo.title
        : (pageTitle ? pageTitle + ' | ' + site.business.name : site.seo.defaultTitle);
    const seoDesc = (page && page.seo && page.seo.description)
        ? page.seo.description
        : site.seo.defaultDescription;
    const seoImage = (page && page.seo && page.seo.ogImage)
        ? page.seo.ogImage
        : (site.seo.ogImage || null);
    %>

    <title><%= seoTitle %></title>
    <meta name="description" content="<%= seoDesc %>">

    <!-- Open Graph -->
    <meta property="og:title"       content="<%= seoTitle %>">
    <meta property="og:description" content="<%= seoDesc %>">
    <meta property="og:type"        content="website">
    <% if (seoImage) { %>
    <meta property="og:image" content="<%= seoImage %>">
    <% } %>

    <% if (typeof faviconUrl !== 'undefined' && faviconUrl) { %>
    <link rel="icon" href="<%= faviconUrl %>">
    <% } %>

    <link href="<%= site.fonts.googleFontsUrl %>" rel="stylesheet">
    <% if (typeof needsLeaflet !== 'undefined' && needsLeaflet) { %>
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin="">
    <% } %>
    <link rel="stylesheet" href="/css/style.css">
    <%- include('theme-script') %>
    <% if (site.design && site.design.borderStyle === 'custom' && site.design.customRadius) {
       const cr = site.design.customRadius; %>
    <script>document.documentElement.style.setProperty('--radius','<%= cr.tl %>px <%= cr.tr %>px <%= cr.br %>px <%= cr.bl %>px');</script>
    <% } %>
</head>
