<%
  const footerCols   = (site.footer && site.footer.cols) || 3;
  const footerBlocks = (site.footer && site.footer.blocks) || [
    { blockId: 'f1', type: 'logo-desc', row: 1, col: 1, colSpan: 1 },
    { blockId: 'f2', type: 'contact',   row: 1, col: 2, colSpan: 1 },
    { blockId: 'f3', type: 'hours',     row: 1, col: 3, colSpan: 1 },
    { blockId: 'f4', type: 'legal',     row: 2, col: 1, colSpan: 3 },
  ];
  const b = site.business || {};
  const h = b.hours   || {};
  const l = b.legal   || {};
%>
<footer class="footer">
  <div class="footer-grid" style="--footer-cols: <%= footerCols %>">
    <% for (const block of footerBlocks) { %>
      <div class="footer-block"
        style="grid-row:<%= block.row %>; grid-column:<%= block.col %> / span <%= block.colSpan || 1 %>">

        <% if (block.type === 'logo-desc') { %>
          <% if (typeof logoUrl !== 'undefined' && logoUrl) { %>
            <img src="<%= logoUrl %>" alt="<%= b.name %>" class="footer-logo">
          <% } else { %>
            <h3><%= b.name %></h3>
          <% } %>
          <% if (b.description) { %><p><%= b.description %></p><% } %>

        <% } else if (block.type === 'contact') { %>
          <h4>Contact</h4>
          <% if (b.phone)   { %><p><a href="tel:<%= b.phone %>"><%= b.phone %></a></p><% } %>
          <% if (b.email)   { %><p><a href="mailto:<%= b.email %>"><%= b.email %></a></p><% } %>
          <% if (b.address) { %><p><%= b.address %></p><% } %>

        <% } else if (block.type === 'hours') { %>
          <h4>Horaires</h4>
          <% if (h.weekdays) { %><p><%= h.weekdays %></p><% } %>
          <% if (h.saturday) { %><p><%= h.saturday %></p><% } %>
          <% if (h.note)     { %><p style="margin-top:0.4rem;font-style:italic;font-size:0.9em"><%= h.note %></p><% } %>

        <% } else if (block.type === 'legal') { %>
          <p style="font-size:0.85rem;opacity:0.7;text-align:center;">
            &copy; <%= l.copyright %> &mdash; Tous droits réservés
            <% if (l.siret)          { %> | SIRET <%= l.siret %><% } %>
            <% if (l.certifications) { %> | <%= l.certifications %><% } %>
          </p>

        <% } else if (block.type === 'richtext') { %>
          <% if (block.content) { %><%- block.content %><% } %>

        <% } else if (block.type === 'social-links') { %>
          <div class="layout-social layout-social-<%= block.direction || 'horizontal' %>"
            data-social-shape="<%= block.shape || 'round' %>"
            data-social-size="<%= block.size || 'md' %>"></div>

        <% } else if (block.type === 'map') { %>
          <div class="layout-map"
            style="min-height:<%= block.height || 300 %>px"
            data-map-provider="<%= block.provider || 'leaflet' %>"
            data-map-address="<%= encodeURIComponent(block.address || '') %>"
            data-map-embed="<%= block.embedUrl || '' %>"></div>

        <% } %>
      </div>
    <% } %>
  </div>
</footer>
