<section class="hero" id="accueil">
    <div class="hero-overlay">
        <div class="container">
            <div class="hero-content">
                <h2 class="hero-title" data-content-key="hero-title">Votre partenaire de confiance</h2>
                <p class="hero-subtitle" data-content-key="hero-subtitle">Expert en renovation alpine depuis plus de 15 ans</p>
                <a href="#contact" class="btn btn-primary" data-content-key="hero-cta">Demander un devis gratuit</a>
            </div>
        </div>
    </div>
    <div class="hero-image" style="background-image: url('https://images.unsplash.com/photo-1506905925346-21bda4d32df4?w=1920&h=1080&fit=crop&q=80');"></div>
</section>

<script>
(function() {
    var HERO_FALLBACKS = [
        'https://images.unsplash.com/photo-1506905925346-21bda4d32df4?w=1920&h=1080&fit=crop&q=80',
        'https://images.unsplash.com/photo-1542273917363-3b1817f69a2d?w=1920&h=1080&fit=crop&q=80',
        'https://images.unsplash.com/photo-1519681393784-d120267933ba?w=1920&h=1080&fit=crop&q=80',
        'https://images.unsplash.com/photo-1464822759023-fed622ff2c3b?w=1920&h=1080&fit=crop&q=80',
        'https://images.unsplash.com/photo-1498837167922-ddd27525d352?w=1920&h=1080&fit=crop&q=80',
    ];

    fetch('/api/carousel/<%= section.carouselId %>/images')
        .then(function(res) { return res.json(); })
        .then(function(data) {
            var apiImages = data.images && data.images.length > 0
                ? data.images.map(function(i) { return i.webpUrl || i.url; })
                : HERO_FALLBACKS;

            var hero = document.getElementById('accueil');
            var existingSlide = hero.querySelector('.hero-image');
            var overlay = hero.querySelector('.hero-overlay');

            if (apiImages.length === 1) {
                if (existingSlide) existingSlide.style.backgroundImage = "url('" + apiImages[0] + "')";
                return;
            }

            if (existingSlide) existingSlide.remove();
            var slides = apiImages.map(function(url, i) {
                var slide = document.createElement('div');
                slide.className = 'hero-image hero-slide' + (i === 0 ? ' active' : '');
                slide.style.backgroundImage = "url('" + url + "')";
                hero.insertBefore(slide, overlay);
                return slide;
            });

            var dots = document.createElement('div');
            dots.className = 'hero-dots';
            slides.forEach(function(_, i) {
                var dot = document.createElement('button');
                dot.className = 'hero-dot' + (i === 0 ? ' active' : '');
                dot.setAttribute('aria-label', 'Slide ' + (i + 1));
                dot.addEventListener('click', function() { goToSlide(i); });
                dots.appendChild(dot);
            });
            hero.appendChild(dots);

            var current = 0;
            var timer;

            function goToSlide(index) {
                slides[current].classList.remove('active');
                dots.children[current].classList.remove('active');
                current = index;
                slides[current].classList.add('active');
                dots.children[current].classList.add('active');
                clearInterval(timer);
                timer = setInterval(nextSlide, 5000);
            }

            function nextSlide() {
                goToSlide((current + 1) % slides.length);
            }

            timer = setInterval(nextSlide, 5000);
        }).catch(function() {});

    // Parallax hero
    window.addEventListener('scroll', function() {
        var scrollPosition = window.pageYOffset;
        if (scrollPosition < window.innerHeight) {
            document.querySelectorAll('#accueil .hero-image').forEach(function(el) {
                el.style.transform = 'translateY(' + (scrollPosition * 0.5) + 'px)';
            });
        }
    });
})();
</script>