<%
const BLOCK_BORDER_WIDTH = { thin: '1px', normal: '2px', thick: '4px' };
const BLOCK_BORDER_RADIUS = { sm: '4px', md: '8px', lg: '16px', pill: '9999px' };

function blockStyle(block, gridStyle) {
  let style = gridStyle;
  const hasBg     = !!block.bg;
  const hasBorder = block.borderWidth && block.borderWidth !== 'none';
  const hasRadius = block.borderRadius && block.borderRadius !== 'none';

  // Ajouter du padding dès qu'une décoration visuelle est présente
  if (hasBg || hasBorder || hasRadius) style += '; padding: 1rem';

  if (hasBg)     style += '; background: ' + block.bg;
  if (block.color) style += '; color: ' + block.color;
  if (hasBorder) {
    const bw = BLOCK_BORDER_WIDTH[block.borderWidth] || '1px';
    const bc = block.borderColor || 'var(--primary)';
    style += '; border: ' + bw + ' solid ' + bc;
  }
  if (hasRadius) {
    style += '; border-radius: ' + (BLOCK_BORDER_RADIUS[block.borderRadius] || '0');
    style += '; overflow: hidden';
  }
  return style;
}
%>
<% const layout = layouts[section.layoutId]; %>
<% if (layout) { %>
<section class="section custom-layout-section" id="layout-<%= section.layoutId %>">
  <div class="container">
    <div class="custom-layout-grid">
      <% for (const block of layout.blocks) { %>
        <% const contentKey = 'layout-' + section.layoutId + '-' + block.blockId; %>
        <% const bcId = section.blockCarousels && section.blockCarousels[block.blockId]; %>
        <% const gridStyle = 'grid-row:' + (block.row || 1) + '; grid-column:' + (block.col || 1) + ' / span ' + (block.colSpan || 1); %>

        <% if (block.type === 'title') { %>
          <<%= block.tag || 'h2' %>
            class="layout-block layout-title"
            style="<%= blockStyle(block, gridStyle) %>"
            data-content-key="<%= contentKey %>"
          >Titre</<%= block.tag || 'h2' %>>

        <% } else if (block.type === 'richtext') { %>
          <div
            class="layout-block layout-richtext"
            style="<%= blockStyle(block, gridStyle) %>"
            data-content-key="<%= contentKey %>"
          ><p>Texte a editer...</p></div>

        <% } else if (block.type === 'image') { %>
          <div
            class="layout-block layout-image layout-image-<%= block.display || 'column' %>"
            style="<%= blockStyle(block, gridStyle) %>"
            <% if (bcId) { %>data-carousel-id="<%= bcId %>"<% } %>
          >
            <div class="layout-image-placeholder">Image</div>
          </div>

        <% } else if (block.type === 'carousel') { %>
          <div
            class="layout-block layout-carousel"
            style="<%= blockStyle(block, gridStyle) %>"
            <% if (bcId) { %>data-carousel-id="<%= bcId %>"<% } %>
          >
            <div class="layout-carousel-container"></div>
          </div>
        <% } else if (block.type === 'social-links') { %>
          <div
            class="layout-block layout-social layout-social-<%= block.direction || 'horizontal' %>"
            style="<%= blockStyle(block, gridStyle) %>"
            data-social-shape="<%= block.shape || 'round' %>"
            data-social-size="<%= block.size || 'md' %>">
          </div>
        <% } else if (block.type === 'map') { %>
          <div
            class="layout-block layout-map"
            style="<%= blockStyle(block, gridStyle) %>; min-height:<%= block.height || 300 %>px"
            data-map-provider="<%= block.provider || 'leaflet' %>"
            data-map-address="<%= encodeURIComponent(block.address || '') %>"
            data-map-embed="<%= block.embedUrl || '' %>">
          </div>
        <% } %>
      <% } %>
    </div>
  </div>
</section>

<script>
(function() {
  var section = document.getElementById('layout-<%= section.layoutId %>');
  if (!section) return;

  // Chargement des images carousel/image
  section.querySelectorAll('[data-carousel-id]').forEach(function(el) {
    var cid = el.dataset.carouselId;
    fetch('/api/carousel/' + cid + '/images')
      .then(function(r) { return r.json(); })
      .then(function(data) {
        var images = data.images || [];
        if (images.length === 0) return;

        if (el.classList.contains('layout-image')) {
          var img = images[0];
          var placeholder = el.querySelector('.layout-image-placeholder');
          if (placeholder) placeholder.remove();
          var imgEl = document.createElement('img');
          imgEl.src = img.webpUrl || img.url;
          imgEl.alt = '';
          imgEl.loading = 'lazy';
          el.appendChild(imgEl);
        } else if (el.classList.contains('layout-carousel')) {
          var container = el.querySelector('.layout-carousel-container');
          if (!container) return;
          images.forEach(function(img) {
            var imgEl = document.createElement('img');
            imgEl.src = img.webpUrl || img.url;
            imgEl.alt = '';
            imgEl.loading = 'lazy';
            container.appendChild(imgEl);
          });
        }
      }).catch(function() {});
  });

  // Réseaux sociaux
  var socialEls = section.querySelectorAll('.layout-social');
  if (socialEls.length > 0) {
    initSocialBlocks(socialEls);
  }

  // Cartes
  section.querySelectorAll('.layout-map').forEach(function(el) {
    initMapBlock(el);
  });
})();
</script>
<% } %>
