<section class="section section-contact" id="contact">
    <div class="container">
        <h2 class="section-title" data-content-key="contact-title">Demandez votre devis gratuit</h2>
        <form class="contact-form" id="contact-form">
            <div class="form-row">
                <div class="form-group">
                    <input type="text" name="name" placeholder="Votre nom" required>
                </div>
                <div class="form-group">
                    <input type="email" name="email" placeholder="Votre email" required>
                </div>
            </div>
            <div class="form-row">
                <div class="form-group">
                    <input type="tel" name="phone" placeholder="Votre telephone">
                </div>
                <div class="form-group">
                    <input type="text" name="location" placeholder="Votre ville">
                </div>
            </div>
            <div class="form-group">
                <textarea name="message" placeholder="Decrivez votre projet..." rows="5" required></textarea>
            </div>

            <%
            const captchaProvider = site.captcha && site.captcha.provider;
            const captchaSiteKey  = site.captcha && site.captcha.siteKey;
            %>

            <% if (captchaProvider === 'turnstile' && captchaSiteKey) { %>
            <div class="form-group text-center">
                <div class="cf-turnstile" data-sitekey="<%= captchaSiteKey %>" data-theme="light"></div>
            </div>
            <% } %>

            <% if (captchaProvider === 'recaptcha' && captchaSiteKey) { %>
            <div class="form-group text-center">
                <div class="g-recaptcha" data-sitekey="<%= captchaSiteKey %>"></div>
            </div>
            <% } %>

            <% if (captchaProvider === 'hcaptcha' && captchaSiteKey) { %>
            <div class="form-group text-center">
                <div class="h-captcha" data-sitekey="<%= captchaSiteKey %>"></div>
            </div>
            <% } %>

            <div id="contact-message"></div>
            <div class="text-center">
                <button type="submit" class="btn btn-primary" id="contact-submit">Envoyer la demande</button>
            </div>
        </form>
    </div>
</section>

<% if (captchaProvider === 'turnstile' && captchaSiteKey) { %>
<script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>
<% } %>
<% if (captchaProvider === 'recaptcha' && captchaSiteKey) { %>
<script src="https://www.google.com/recaptcha/api.js" async defer></script>
<% } %>
<% if (captchaProvider === 'hcaptcha' && captchaSiteKey) { %>
<script src="https://js.hcaptcha.com/1/api.js" async defer></script>
<% } %>

<script>
document.getElementById('contact-form').addEventListener('submit', async function(e) {
    e.preventDefault();
    var form      = e.target;
    var submitBtn = document.getElementById('contact-submit');
    var msgEl     = document.getElementById('contact-message');

    <% if (captchaProvider === 'turnstile' && captchaSiteKey) { %>
    var token = form.querySelector('[name="cf-turnstile-response"]') &&
                form.querySelector('[name="cf-turnstile-response"]').value;
    if (!token) {
        msgEl.className = 'contact-msg contact-msg--error';
        msgEl.textContent = 'Veuillez valider le captcha.';
        return;
    }
    <% } %>
    <% if (captchaProvider === 'recaptcha' && captchaSiteKey) { %>
    var token = form.querySelector('[name="g-recaptcha-response"]') &&
                form.querySelector('[name="g-recaptcha-response"]').value;
    if (!token) {
        msgEl.className = 'contact-msg contact-msg--error';
        msgEl.textContent = 'Veuillez valider le captcha.';
        return;
    }
    <% } %>
    <% if (captchaProvider === 'hcaptcha' && captchaSiteKey) { %>
    var token = form.querySelector('[name="h-captcha-response"]') &&
                form.querySelector('[name="h-captcha-response"]').value;
    if (!token) {
        msgEl.className = 'contact-msg contact-msg--error';
        msgEl.textContent = 'Veuillez valider le captcha.';
        return;
    }
    <% } %>

    submitBtn.disabled = true;
    submitBtn.textContent = 'Envoi en cours...';
    msgEl.textContent = '';

    try {
        var body = {
            name:    form.name.value,
            email:   form.email.value,
            phone:   form.phone.value,
            message: form.message.value
        };
        <% if (captchaProvider === 'turnstile' && captchaSiteKey) { %>
        body['cf-turnstile-response'] = token;
        <% } else if (captchaProvider === 'recaptcha' && captchaSiteKey) { %>
        body['g-recaptcha-response'] = token;
        <% } else if (captchaProvider === 'hcaptcha' && captchaSiteKey) { %>
        body['h-captcha-response'] = token;
        <% } %>

        var res  = await fetch('/api/contact', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(body)
        });
        var data = await res.json();
        if (res.ok) {
            form.innerHTML = '<p class="contact-msg contact-msg--success">Votre demande a bien ete envoyee ! Nous vous repondrons rapidement.</p>';
        } else {
            throw new Error(data.error || 'Erreur lors de l\'envoi');
        }
    } catch (err) {
        msgEl.className = 'contact-msg contact-msg--error';
        msgEl.textContent = err.message;
        submitBtn.disabled = false;
        submitBtn.textContent = 'Envoyer la demande';
        if (window.turnstile)  turnstile.reset();
        if (window.grecaptcha) grecaptcha.reset();
        if (window.hcaptcha)   hcaptcha.reset();
    }
});
</script>
