<section class="s1">
    <div class="container">
        <div class="section-header reveal">
            <span class="section-tag" data-content-key="s1-tag">&mdash; Solidite & Fondations &mdash;</span>
            <h2 class="section-title" style="color:var(--primary-dark)" data-content-key="s1-title">Maconnerie & Gros Oeuvre</h2>
        </div>

        <div class="bento reveal" id="bento-<%= section.carouselId %>">
            <div class="bento-hero">
                <img src="https://images.unsplash.com/photo-1590012314607-cda9d9b699ae?w=900&h=700&fit=crop&q=80" alt="Maconnerie gros oeuvre">
                <div class="bento-hero-text">
                    <span class="tag-pill">Projet phare</span>
                    <h3 data-content-key="bento-hero-title">Fondation & Soubassement<br>Chalet Belledonne</h3>
                    <p data-content-key="bento-hero-desc">Dalles beton arme, reprises en sous-oeuvre, maconnerie traditionnelle pierre</p>
                </div>
            </div>
            <div class="bento-card">
                <img src="https://images.unsplash.com/photo-1504307651254-35680f356dfd?w=600&h=350&fit=crop&q=80" alt="Mur porteur">
                <div class="bento-card-info">
                    <span class="tag-pill slate">Murs porteurs</span>
                    <h4>Parpaing & Beton arme</h4>
                </div>
                <div class="bento-card-overlay">
                    <span class="tag-pill slate">Murs porteurs</span>
                    <p>Creation de murs porteurs en parpaing enduit, renforcement de structure existante, coulage poteaux beton arme.</p>
                </div>
            </div>
            <div class="bento-card">
                <img src="https://images.unsplash.com/photo-1581094794329-c8112a89af12?w=600&h=350&fit=crop&q=80" alt="Dalle beton">
                <div class="bento-card-info">
                    <span class="tag-pill green">Dalles</span>
                    <h4>Dalle beton avec chauffage</h4>
                </div>
                <div class="bento-card-overlay">
                    <span class="tag-pill green">Dalles beton</span>
                    <p>Pose de dalle chauffante, isolation sous-dalle, chape ciment lissee, compatible plancher bois massif.</p>
                </div>
            </div>
        </div>

        <div class="stats-bar reveal">
            <div class="stat-item">
                <span class="stat-number" data-count="23"><span>0</span></span>
                <span class="stat-label">Fondations realisees</span>
            </div>
            <div class="stat-item">
                <span class="stat-number" data-count="47"><span>0</span></span>
                <span class="stat-label">Murs porteurs</span>
            </div>
            <div class="stat-item">
                <span class="stat-number" data-count="12"><span>0</span></span>
                <span class="stat-label">Dalles beton</span>
            </div>
        </div>
    </div>
</section>

<svg class="divider" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1440 80" preserveAspectRatio="none" style="background:var(--bg)">
    <path d="M0,0 L0,40 C180,80 360,0 540,40 C720,80 900,0 1080,40 C1260,80 1440,20 1440,40 L1440,80 L0,80 Z" fill="#37474f"/>
</svg>

<script>
(function() {
    // Count-up numbers
    function countUp(el, target, duration) {
        duration = duration || 1600;
        var start = 0;
        var step = target / (duration / 16);
        var span = el.querySelector('span');
        var timer = setInterval(function() {
            start = Math.min(start + step, target);
            span.textContent = Math.floor(start);
            if (start >= target) clearInterval(timer);
        }, 16);
    }

    var statsObserver = new IntersectionObserver(function(entries) {
        entries.forEach(function(entry) {
            if (entry.isIntersecting) {
                entry.target.querySelectorAll('[data-count]').forEach(function(el) {
                    countUp(el, parseInt(el.dataset.count));
                });
                statsObserver.unobserve(entry.target);
            }
        });
    }, { threshold: 0.5 });

    var statsBar = document.querySelector('.stats-bar');
    if (statsBar) statsObserver.observe(statsBar);

    // Charger les images depuis l'API
    fetch('/api/carousel/<%= section.carouselId %>/images')
        .then(function(res) { return res.json(); })
        .then(function(data) {
            if (data.images && data.images.length > 0) {
                var allImgs = document.querySelectorAll('#bento-<%= section.carouselId %> .bento-hero img, #bento-<%= section.carouselId %> .bento-card img');
                data.images.forEach(function(img, i) {
                    if (allImgs[i]) allImgs[i].src = img.webpUrl || img.url;
                });
            }
        }).catch(function() {});
})();
</script>