# ────────────────────────────────────────────────────────────────────────────
# Nimble environment variables
# Copy this file to .env.local and fill in the values
# On Hostinger: set these variables in hPanel → Node.js → Environment
# ────────────────────────────────────────────────────────────────────────────

# REQUIRED — Session secret (32 characters minimum)
# Generate with: openssl rand -base64 32
SESSION_SECRET=change-this-value-to-a-random-string-of-at-least-32-characters

# Optional — Force secure cookies (true in production with HTTPS)
# COOKIE_SECURE=true

# Optional — Admin username (default: admin)
# ADMIN_USERNAME=admin

# Admin password (bcrypt hash, single quotes required because of $)
# Generate with: node -e "const b=require('bcryptjs'); b.hash('mypassword',10).then(h=>console.log(h))"
# ADMIN_PASSWORD_HASH='$2b$10$...'
