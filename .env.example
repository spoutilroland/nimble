# ────────────────────────────────────────────────────────────────────────────
# Variables d'environnement Nimble
# Copier ce fichier en .env.local et remplir les valeurs
# Sur Hostinger : configurer ces variables dans hPanel → Node.js → Environment
# ────────────────────────────────────────────────────────────────────────────

# OBLIGATOIRE — Secret de session (32 caractères minimum)
# Générer avec : openssl rand -base64 32
SESSION_SECRET=changez-cette-valeur-par-une-chaine-aleatoire-de-32-caracteres-minimum

# Optionnel — Forcer les cookies sécurisés (true en production HTTPS)
# COOKIE_SECURE=true

# Optionnel — Nom d'utilisateur admin (défaut : admin)
# ADMIN_USERNAME=admin

# Mot de passe admin (hash bcrypt, guillemets simples obligatoires à cause des $)
# Générer avec : node -e "const b=require('bcryptjs'); b.hash('monmotdepasse',10).then(h=>console.log(h))"
# ADMIN_PASSWORD_HASH='$2b$10$...'
