# Server Configuration
PORT=3000

# Admin Credentials
# Use a temporary password here for first login, then change it via the back-office.
# The back-office will hash and store it securely in data/admin.json.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme123

# Session Secret (generate a random string for production)
SESSION_SECRET=your_secret_session

# Email Configuration (use your SMTP provider)
EMAIL_SERVICE=gmail
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=contact@your-domain.com
EMAIL_PASS=xxxx-xxxx-xxxx-xxxx
EMAIL_FROM=noreply@your-domain.com
EMAIL_TO=exemple@your-domain.com

# Captcha — generic secret key (Turnstile, reCAPTCHA v2, hCaptcha)
# Can be configured in the backoffice
# NEVER expose this key in the browser
CAPTCHA_SECRET_KEY=0x4AAAAAAA_xxxxxxxxxxxxxxxxxxxxxxxx

# Node Environment
NODE_ENV=development
