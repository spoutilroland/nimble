# Dépendances
node_modules/

# Build Next.js
.next/
tsconfig.tsbuildinfo

# Variables d'environnement (contient secrets, hash mdp, clés SMTP)
.env

# Données client générées à l'exécution (ne jamais écraser via git)
data/*.json
data/snapshots/

# Uploads utilisateur (fichiers binaires, hors scope git)
uploads/
public/uploads/
# Exception : route Next.js de serving des uploads (code source, pas des fichiers)
!app/uploads/

# Logs
logs/
*.log
npm-debug.log*

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/

# Mémoire Claude (données de session privées)
.claude/
CLAUDE.md

# Repomix / Repopack output
repomix-output.xml
repomix-output.txt
repopack-output.xml
repopack-output.txt

# Notes de session (privées)
done.md

# Rapports d'audit (données sensibles, garder en local uniquement)
SECURITY_AUDIT.md
SECURITY_CORRECTIONS.md
.vercel
